{
  "manifest_version": 3,
  "name": "会場探し一括検索",
  "version": "3.0.0",
  "description": "Google検索で施設を収集し、各サイトから料金を汎用抽出してExcel出力",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://www.google.co.jp/*",
    "https://www.google.com/*",
    "https://*/*"
  ],
  "action": {
    "default_icon": {
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.co.jp/search*",
        "https://www.google.com/search*"
      ],
      "js": ["content/google.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.instabase.jp/*",
        "https://www.spacemarket.com/*",
        "https://www.spacee.jp/*"
      ],
      "js": ["content/platform.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
